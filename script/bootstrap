#!/usr/bin/env bash
set -euo pipefail

# Idempotent bootstrap for macOS (Apple Silicon) and Ubuntu 24.04:
# - base packages
# - cloning/checking out an existing dotfiles repo via bare-repo pattern
# - Oh My Zsh installation without clobbering ~/.zshrc
# - modern asdf installation
# - automatic `asdf install` before exit
#
# Required:
#   DOTFILES_REPO_URL=git@github.com:you/dotfiles.git ./bootstrap.sh
# or:
#   DOTFILES_REPO_URL=https://github.com/you/dotfiles.git ./bootstrap.sh
#
# Optional:
#   ASDF_VERSION=0.18.1 ./bootstrap.sh

ASDF_VERSION="${ASDF_VERSION:-0.18.1}"
DOTFILES_REPO_URL="${DOTFILES_REPO_URL:-https://github.com/juan-lee/dotfiles.git}"
DOTFILES_GIT_DIR="${DOTFILES_GIT_DIR:-$HOME/.cfg}"
DOTFILES_BACKUP_DIR="${DOTFILES_BACKUP_DIR:-$HOME/.config-backup}"
ASDF_BIN_PATH="${ASDF_BIN_PATH:-/usr/local/bin/asdf}"
OS="$(uname -s | tr '[:upper:]' '[:lower:]')"

log() {
  printf '\n==> %s\n' "$*"
}

have() {
  command -v "$1" >/dev/null 2>&1
}

require_env() {
  local name="$1"
  if [[ -z "${!name:-}" ]]; then
    echo "ERROR: environment variable $name is required" >&2
    exit 1
  fi
}

ensure_line() {
  local file="$1"
  local line="$2"
  touch "$file"
  grep -Fqx "$line" "$file" || printf '%s\n' "$line" >>"$file"
}

detect_arch() {
  local raw
  case "$OS" in
    linux)  raw="$(dpkg --print-architecture)" ;;
    darwin) raw="$(uname -m)" ;;
    *)      echo "ERROR: unsupported OS: $OS" >&2; exit 1 ;;
  esac
  case "$raw" in
    amd64)          echo "amd64" ;;
    arm64|aarch64)  echo "arm64" ;;
    *)
      echo "ERROR: unsupported architecture: $raw" >&2
      exit 1
      ;;
  esac
}

portable_sed_i() {
  if [[ "$OS" == "darwin" ]]; then
    sed -i '' "$@"
  else
    sed -i "$@"
  fi
}

config_git() {
  git --git-dir="$DOTFILES_GIT_DIR" --work-tree="$HOME" "$@"
}

install_base_packages_linux() {
  sudo apt-get update
  sudo apt-get install -y \
    bison \
    build-essential \
    ca-certificates \
    curl \
    git \
    gpg \
    libevent-dev \
    libncurses-dev \
    pkg-config \
    unzip \
    zsh
}

install_base_packages_darwin() {
  if ! have brew; then
    log "Installing Homebrew"
    NONINTERACTIVE=1 /bin/bash -c \
      "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
  fi
  brew install git gnupg unzip zsh
}

install_base_packages() {
  log "Installing base packages"
  case "$OS" in
    linux)  install_base_packages_linux ;;
    darwin) install_base_packages_darwin ;;
    *)      echo "ERROR: unsupported OS: $OS" >&2; exit 1 ;;
  esac
}

install_asdf_binary() {
  local want_version="v${ASDF_VERSION}"

  if have asdf; then
    local current
    current="$(asdf version 2>/dev/null | awk '{print $1}' || true)"
    if [[ "$current" == "$want_version" ]]; then
      log "asdf ${want_version} already installed"
      return
    fi
    log "asdf present but version is ${current:-unknown}; installing ${want_version}"
  else
    log "Installing asdf ${want_version}"
  fi

  local tmpdir asdf_arch tarball url
  tmpdir="$(mktemp -d)"
  trap 'rm -rf "${tmpdir:-}"' RETURN

  asdf_arch="$(detect_arch)"
  tarball="asdf-v${ASDF_VERSION}-${OS}-${asdf_arch}.tar.gz"
  url="https://github.com/asdf-vm/asdf/releases/download/v${ASDF_VERSION}/${tarball}"

  curl -fsSL "$url" -o "${tmpdir}/${tarball}"
  tar -xzf "${tmpdir}/${tarball}" -C "$tmpdir"
  sudo install -m 0755 "${tmpdir}/asdf" "$ASDF_BIN_PATH"
}

ensure_asdf_dirs() {
  log "Ensuring asdf data directories exist"
  mkdir -p "$HOME/.asdf"/{downloads,installs,plugins,shims}
}

clone_or_validate_dotfiles_repo() {
  require_env DOTFILES_REPO_URL

  if [[ -d "$DOTFILES_GIT_DIR" ]]; then
    log "Dotfiles bare repo already exists at $DOTFILES_GIT_DIR"
    return
  fi

  log "Cloning bare dotfiles repo into $DOTFILES_GIT_DIR"
  git clone --bare "$DOTFILES_REPO_URL" "$DOTFILES_GIT_DIR"
}

backup_checkout_conflicts() {
  mkdir -p "$DOTFILES_BACKUP_DIR"

  local checkout_output
  checkout_output="$(
    config_git checkout 2>&1 || true
  )"

  if grep -q "would be overwritten by checkout" <<<"$checkout_output"; then
    log "Backing up pre-existing files that conflict with dotfiles checkout"

    printf '%s\n' "$checkout_output" |
      sed -n '/would be overwritten by checkout/,$p' |
      sed '1d' |
      sed '/^$/d' |
      sed 's/^[[:space:]]*//' |
      while read -r path; do
        [[ -z "$path" ]] && continue
        mkdir -p "$DOTFILES_BACKUP_DIR/$(dirname "$path")"
        if [[ -e "$HOME/$path" || -L "$HOME/$path" ]]; then
          mv "$HOME/$path" "$DOTFILES_BACKUP_DIR/$path"
        fi
      done
    config_git checkout
  else
    if ! config_git checkout >/dev/null 2>&1; then
      echo "$checkout_output" >&2
      echo "ERROR: failed to checkout dotfiles" >&2
      exit 1
    fi
  fi
}

checkout_dotfiles() {
  log "Checking out dotfiles into $HOME"

  if config_git rev-parse --is-bare-repository >/dev/null 2>&1; then
    backup_checkout_conflicts
    config_git config --local status.showUntrackedFiles no
  else
    echo "ERROR: $DOTFILES_GIT_DIR is not a bare git repository" >&2
    exit 1
  fi
}

install_oh_my_zsh() {
  if [[ -d "$HOME/.oh-my-zsh" ]]; then
    log "Oh My Zsh already installed"
    return
  fi

  log "Installing Oh My Zsh without overwriting ~/.zshrc"
  RUNZSH=no CHSH=no KEEP_ZSHRC=yes \
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" \
    --unattended --keep-zshrc
}

ensure_asdfrc() {
  local file="$HOME/.asdfrc"
  log "Ensuring $file"
  touch "$file"

  if ! grep -Eq '^[[:space:]]*legacy_version_file[[:space:]]*=' "$file"; then
    printf '%s\n' 'legacy_version_file = yes' >>"$file"
  fi
  if ! grep -Eq '^[[:space:]]*plugin_repository_last_check_duration[[:space:]]*=' "$file"; then
    printf '%s\n' 'plugin_repository_last_check_duration = 60' >>"$file"
  fi
  if ! grep -Eq '^[[:space:]]*concurrency[[:space:]]*=' "$file"; then
    printf '%s\n' 'concurrency = auto' >>"$file"
  fi
}

ensure_zshrc_exists() {
  if [[ ! -f "$HOME/.zshrc" ]]; then
    log "Creating minimal ~/.zshrc"
    cat >"$HOME/.zshrc" <<'EOF'
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
plugins=(dotenv git kubectl tmux vi-mode)

export ASDF_DATA_DIR="$HOME/.asdf"
export PATH="$ASDF_DATA_DIR/shims:$PATH"

alias config='git --git-dir=$HOME/.cfg/ --work-tree=$HOME'

source "$ZSH/oh-my-zsh.sh"
EOF
  fi
}

ensure_zshrc_asdf_block() {
  local file="$HOME/.zshrc"
  log "Ensuring ~/.zshrc contains modern asdf PATH setup"

  portable_sed_i '/asdf\.sh/d' "$file"
  portable_sed_i '/completions\/asdf\.bash/d' "$file"

  ensure_line "$file" 'export ASDF_DATA_DIR="$HOME/.asdf"'
  ensure_line "$file" 'export PATH="$ASDF_DATA_DIR/shims:$PATH"'
}

ensure_zshrc_ohmyzsh_block() {
  local file="$HOME/.zshrc"
  log "Ensuring ~/.zshrc contains Oh My Zsh bootstrap"

  ensure_line "$file" 'export ZSH="$HOME/.oh-my-zsh"'

  if ! grep -Eq '^ZSH_THEME=' "$file"; then
    printf '%s\n' 'ZSH_THEME="robbyrussell"' >>"$file"
  fi

  if ! grep -Eq '^plugins=\(' "$file"; then
    printf '%s\n' 'plugins=(dotenv git kubectl tmux vi-mode)' >>"$file"
  fi

  ensure_line "$file" 'source "$ZSH/oh-my-zsh.sh"'
}

ensure_config_alias() {
  log "Ensuring config alias is present in ~/.zshrc"
  ensure_line "$HOME/.zshrc" "alias config='git --git-dir=\$HOME/.cfg/ --work-tree=\$HOME'"
}

set_zsh_as_login_shell() {
  local zsh_path
  zsh_path="$(command -v zsh)"
  if [[ "${SHELL:-}" == "$zsh_path" ]]; then
    log "Login shell already set to zsh"
    return
  fi

  log "Setting login shell to zsh"
  if [[ "$OS" == "darwin" ]] && ! grep -Fxq "$zsh_path" /etc/shells; then
    log "Adding $zsh_path to /etc/shells"
    echo "$zsh_path" | sudo tee -a /etc/shells >/dev/null
  fi
  chsh -s "$zsh_path" || true
}

source_asdf_env_for_script() {
  export ASDF_DATA_DIR="$HOME/.asdf"
  export PATH="$HOME/.asdf/shims:/usr/local/bin:$PATH"
  if [[ "$OS" == "darwin" && -d /opt/homebrew/bin ]]; then
    export PATH="/opt/homebrew/bin:$PATH"
  fi
}

require_tool_versions() {
  if [[ ! -f "$HOME/.tool-versions" ]]; then
    echo "ERROR: ~/.tool-versions not found after dotfiles checkout" >&2
    exit 1
  fi
}

install_from_tool_versions() {
  require_tool_versions
  source_asdf_env_for_script

  if ! have asdf; then
    echo "ERROR: asdf not found on PATH after installation" >&2
    exit 1
  fi

  log "Adding missing asdf plugins from ~/.tool-versions"
  awk '
    /^[[:space:]]*#/ {next}
    /^[[:space:]]*$/ {next}
    {print $1}
  ' "$HOME/.tool-versions" | while read -r plugin; do
    [[ -z "$plugin" ]] && continue
    if asdf plugin list 2>/dev/null | grep -Fxq "$plugin"; then
      echo "  - plugin already present: $plugin"
    else
      echo "  - adding plugin: $plugin"
      asdf plugin add "$plugin"
    fi
  done

  log "Running asdf install from \$HOME"
  (
    cd "$HOME"
    asdf install
  )

  log "Current asdf versions"
  (
    cd "$HOME"
    asdf current || true
  )
}

main() {
  require_env DOTFILES_REPO_URL

  install_base_packages
  clone_or_validate_dotfiles_repo
  checkout_dotfiles
  install_oh_my_zsh
  install_asdf_binary
  ensure_asdf_dirs
  ensure_asdfrc
  ensure_zshrc_exists
  ensure_zshrc_asdf_block
  ensure_zshrc_ohmyzsh_block
  ensure_config_alias
  config_git config --local status.showUntrackedFiles no
  set_zsh_as_login_shell
  install_from_tool_versions

  log "Bootstrap complete"
  echo "Open a new shell or run: exec zsh"
  echo "Dotfile conflicts, if any, were moved to: $DOTFILES_BACKUP_DIR"
}

main "$@"

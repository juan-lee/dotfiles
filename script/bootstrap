#!/usr/bin/env bash
set -euo pipefail

# Minimal Ubuntu 24.04 bootstrap:
# - installs base packages
# - installs asdf (binary)
# - installs Oh My Zsh without overwriting ~/.zshrc
# - initializes a bare dotfiles repo at ~/.cfg
# - writes starter ~/.zshrc, ~/.asdfrc, ~/.tool-versions
# - makes an initial dotfiles commit

ASDF_VERSION="${ASDF_VERSION:-0.18.1}"
DOTFILES_REPO_URL="${DOTFILES_REPO_URL:-git@github.com:juan-lee/dotfiles.git}"   # optional: git@github.com:you/dotfiles.git
GIT_USER_NAME="${GIT_USER_NAME:-Juan-Lee Pang}"
GIT_USER_EMAIL="${GIT_USER_EMAIL:-jpang@coreweave.com}"

need_cmd() {
  command -v "$1" >/dev/null 2>&1
}

append_if_missing() {
  local file="$1"
  local line="$2"
  touch "$file"
  grep -Fqx "$line" "$file" || printf '%s\n' "$line" >> "$file"
}

echo "==> Installing Ubuntu packages"
sudo apt-get update
sudo apt-get install -y \
  bash \
  ca-certificates \
  curl \
  git \
  gpg \
  unzip \
  zsh

echo "==> Installing asdf ${ASDF_VERSION}"
ARCH="$(dpkg --print-architecture)"
case "$ARCH" in
  amd64) ASDF_ARCH="amd64" ;;
  arm64) ASDF_ARCH="arm64" ;;
  *)
    echo "Unsupported architecture: $ARCH"
    exit 1
    ;;
esac

TMPDIR="$(mktemp -d)"
trap 'rm -rf "$TMPDIR"' EXIT

ASDF_TARBALL="asdf-v${ASDF_VERSION}-linux-${ASDF_ARCH}.tar.gz"
ASDF_URL="https://github.com/asdf-vm/asdf/releases/download/v${ASDF_VERSION}/${ASDF_TARBALL}"

curl -fsSL "$ASDF_URL" -o "${TMPDIR}/${ASDF_TARBALL}"
tar -xzf "${TMPDIR}/${ASDF_TARBALL}" -C "${TMPDIR}"
sudo install -m 0755 "${TMPDIR}/asdf" /usr/local/bin/asdf

echo "==> Preparing ~/.asdf directories"
mkdir -p "$HOME/.asdf"/{downloads,installs,plugins,shims}

echo "==> Installing Oh My Zsh (do not overwrite ~/.zshrc)"
if [ ! -d "$HOME/.oh-my-zsh" ]; then
  RUNZSH=no CHSH=no KEEP_ZSHRC=yes \
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended --keep-zshrc
else
  echo "Oh My Zsh already installed; skipping"
fi

echo "==> Writing ~/.asdfrc"
cat > "$HOME/.asdfrc" <<'EOF'
legacy_version_file = yes
plugin_repository_last_check_duration = 60
concurrency = auto
EOF

echo "==> Writing starter ~/.tool-versions"
if [ ! -f "$HOME/.tool-versions" ]; then
  cat > "$HOME/.tool-versions" <<'EOF'
# Edit these to the exact versions you want, then run: asdf install
nodejs 22.14.0
python 3.12.9
EOF
fi

echo "==> Writing ~/.zshrc"
cat > "$HOME/.zshrc" <<'EOF'
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
plugins=(git)

# asdf: modern setup uses the binary on PATH plus shims on PATH.
export ASDF_DATA_DIR="$HOME/.asdf"
export PATH="$ASDF_DATA_DIR/shims:$PATH"

# Dotfiles bare repo alias
alias config='git --git-dir=$HOME/.cfg/ --work-tree=$HOME'

source "$ZSH/oh-my-zsh.sh"
EOF

echo "==> Initializing bare dotfiles repo"
if [ ! -d "$HOME/.cfg" ]; then
  git init --bare "$HOME/.cfg"
fi

config() {
  git --git-dir="$HOME/.cfg/" --work-tree="$HOME" "$@"
}

config config --local status.showUntrackedFiles no

echo "==> Optional git identity"
if [ -n "$GIT_USER_NAME" ]; then
  git config --global user.name "$GIT_USER_NAME"
fi
if [ -n "$GIT_USER_EMAIL" ]; then
  git config --global user.email "$GIT_USER_EMAIL"
fi

echo "==> Tracking minimal dotfiles"
config add .zshrc .asdfrc .tool-versions
if ! config diff --cached --quiet; then
  config commit -m "Initial Ubuntu bootstrap: zsh, asdf, dotfiles"
else
  echo "Nothing new to commit"
fi

echo "==> Optional remote"
if [ -n "$DOTFILES_REPO_URL" ]; then
  if ! config remote get-url origin >/dev/null 2>&1; then
    config remote add origin "$DOTFILES_REPO_URL"
  fi
  config branch -M main
  echo "Remote configured at origin; push with:"
  echo "  config push -u origin main"
fi

echo "==> Switching login shell to zsh"
if [ "${SHELL:-}" != "$(command -v zsh)" ]; then
  chsh -s "$(command -v zsh)" || true
fi

cat <<'EOF'

Done.

Next steps:
  1. Start a fresh shell session (or run: exec zsh)
  2. Verify:
       asdf version
       type -a asdf
  3. Add plugins for the tools you want, for example:
       asdf plugin add nodejs
       asdf plugin add python
  4. Install everything in ~/.tool-versions:
       cd ~ && asdf install
  5. Check what is active:
       asdf current

Dotfiles usage:
  config status
  config add ~/.gitconfig
  config commit -m "Track gitconfig"

EOF
